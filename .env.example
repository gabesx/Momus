# Copy to repo root as .env.local, then:
#   ln -sfn ../../.env.local apps/web/.env.local
#
# --- Remote Momus (sdzoovwjcjqjgfoqszpf, ap-northeast-2) ---
NEXT_PUBLIC_SUPABASE_URL=https://sdzoovwjcjqjgfoqszpf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# --- Local Momus stack (ports remapped to avoid clashes with other projects) ---
# After `supabase start`, use keys from `supabase status`:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon from status>
# SUPABASE_SERVICE_ROLE_KEY=<service_role from status>
# Studio: http://127.0.0.1:54423
# DB: postgresql://postgres:postgres@127.0.0.1:54422/postgres

# Optional direct Postgres URL (Dashboard → Database)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# App timezone (BB calculations, Asia/Jakarta)
TZ=Asia/Jakarta
NODE_ENV=development

# Jira connection is stored in public.settings (not env):
#   jira_url, jira_username, jira_api_token, jira_enabled
# Edit via Settings UI or SQL — never commit tokens.

# Inngest (Phase 2)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Local / Vitest only — never set on Vercel production.
# When true and NODE_ENV !== 'production', APIs use a seeded Momus user without Supabase Auth.
# MOMUS_DEV_AUTH_BYPASS=true
# MOMUS_DEV_USER_EMAIL=admin@momus.local

# BB-SYNC-07: run sync inline after HTTP response when Inngest is not configured (default in non-prod)
# SYNC_INLINE_AFTER_RESPONSE=true
