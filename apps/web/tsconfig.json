{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@momus/shared": ["../../packages/shared/src/index.ts"],
      "@momus/shared/*": ["../../packages/shared/src/*"],
      "@momus/infra": ["../../packages/infra/src/index.ts"],
      "@momus/infra/*": ["../../packages/infra/src/*"]
    },
    "allowJs": true,
    "incremental": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
